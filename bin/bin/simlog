#!/bin/zsh
# simlog - Stream iOS simulator logs filtered by subsystem and optional category/categories

set -uo pipefail

RED='\033[0;31m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
BOLD='\033[1m'
NC='\033[0m'

usage() {
    echo "Usage: $(basename "$0") -s <subsystem> [-c <category>] [-c <category> ...]"
    echo ""
    echo "Stream debug logs from the booted iOS simulator filtered by subsystem and"
    echo "optional category. Repeat -c to filter multiple categories."
    echo ""
    echo "Options:"
    echo "  -s, --subsystem <name>   Subsystem to filter (required)"
    echo "  -c, --category  <name>   Category to filter (optional, repeatable)"
    echo "                           Supports wildcards: 'Net*' (prefix), '*work*' (contains)"
    echo "  -h, --help               Show this help message"
    echo ""
    echo "Examples:"
    echo "  $(basename "$0") -s com.walmart.app"
    echo "  $(basename "$0") -s com.walmart.app -c Networking"
    echo "  $(basename "$0") -s com.walmart.app -c Networking -c Auth -c Cache"
    echo "  $(basename "$0") -s com.walmart.app -c 'Net*'          # prefix match"
    echo "  $(basename "$0") -s com.walmart.app -c '*work*'        # contains match"
    echo "  $(basename "$0") -s com.walmart.app -c 'Net*' -c Auth  # mixed"
    exit "${1:-1}"
}

SUBSYSTEM=""
CATEGORIES=()

while [[ $# -gt 0 ]]; do
    case "$1" in
        -s|--subsystem)
            SUBSYSTEM="$2"
            shift 2
            ;;
        -c|--category)
            CATEGORIES+=("$2")
            shift 2
            ;;
        -h|--help)
            usage 0
            ;;
        *)
            echo -e "${RED}Error: Unknown option '$1'${NC}" >&2
            echo ""
            usage 1
            ;;
    esac
done

if [[ -z "$SUBSYSTEM" ]]; then
    echo -e "${RED}Error: --subsystem is required${NC}" >&2
    echo ""
    usage 1
fi

# Build NSPredicate
PREDICATE="subsystem == \"$SUBSYSTEM\""

if [[ ${#CATEGORIES[@]} -gt 0 ]]; then
    CAT_PRED=""
    for cat in "${CATEGORIES[@]}"; do
        if [[ -n "$CAT_PRED" ]]; then
            CAT_PRED+=" OR "
        fi
        # Use LIKE for wildcard patterns (*), otherwise exact match
        if [[ "$cat" == *"*"* ]]; then
            CAT_PRED+="category LIKE \"$cat\""
        else
            CAT_PRED+="category == \"$cat\""
        fi
    done
    PREDICATE+=" AND ($CAT_PRED)"
fi

echo -e "${BOLD}Streaming logs...${NC}"
echo -e "  ${CYAN}Subsystem:${NC}  $SUBSYSTEM"
if [[ ${#CATEGORIES[@]} -gt 0 ]]; then
    echo -e "  ${CYAN}Categories:${NC} ${CATEGORIES[*]}"
fi
echo -e "  ${CYAN}Level:${NC}      debug"
echo -e "  ${CYAN}Style:${NC}      compact"
echo ""
echo -e "${YELLOW}Press Ctrl+C to stop${NC}"
echo ""

xcrun simctl spawn booted log stream \
    --level=debug \
    --predicate "$PREDICATE" \
    --style compact
