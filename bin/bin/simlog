#!/bin/zsh
# simlog - Stream iOS simulator logs filtered by subsystem and optional category/categories

set -uo pipefail
setopt BASH_REMATCH KSH_ARRAYS

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
BOLD='\033[1m'
NC='\033[0m'

usage() {
    echo "Usage: $(basename "$0") [select simulator] | -s <subsystem> [-c <category>] [-c <category> ...]"
    echo ""
    echo "Stream debug logs from an iOS simulator filtered by subsystem and"
    echo "optional category. Repeat -c to filter multiple categories."
    echo ""
    echo "Actions:"
    echo "  select simulator         Pick default simulator (saved in .simlogrc)"
    echo "  set subsystem <name>     Save default subsystem in .simlogrc"
    echo ""
    echo "Options:"
    echo "  -s, --subsystem <name>   Subsystem to filter (required if not in .simlogrc)"
    echo "  -c, --category  <name>   Category to filter (optional, repeatable)"
    echo "                           Supports wildcards: 'Net*' (prefix), '*work*' (contains)"
    echo "  --simulator-id <uuid>    Override saved simulator (defaults to booted)"
    echo "  -h, --help               Show this help message"
    echo ""
    echo "Examples:"
    echo "  $(basename "$0") select simulator"
    echo "  $(basename "$0") set subsystem com.walmart.app"
    echo "  $(basename "$0") -s com.walmart.app"
    echo "  $(basename "$0") -s com.walmart.app -c Networking"
    echo "  $(basename "$0") -s com.walmart.app -c Networking -c Auth -c Cache"
    echo "  $(basename "$0") -s com.walmart.app -c 'Net*'          # prefix match"
    echo "  $(basename "$0") -s com.walmart.app -c '*work*'        # contains match"
    echo "  $(basename "$0") -s com.walmart.app -c 'Net*' -c Auth  # mixed"
    exit "${1:-1}"
}

SUBSYSTEM=""
CATEGORIES=()
SIMULATOR_NAME=""
SIMULATOR_ID=""
SIMULATOR_OS=""
ACTION=""
SUB_ACTION=""

# Load saved defaults from .simlogrc
SIMLOG_CONFIG=".simlogrc"
if [[ -f "$SIMLOG_CONFIG" ]]; then
    source "$SIMLOG_CONFIG"
fi

# Write or update a KEY="VALUE" pair in the config file, or remove it if value is empty.
set_config() {
    local key="$1" value="$2"
    if [[ -z "$value" ]]; then
        if [[ -f "$SIMLOG_CONFIG" ]] && grep -q "^${key}=" "$SIMLOG_CONFIG"; then
            grep -v "^${key}=" "$SIMLOG_CONFIG" > "$SIMLOG_CONFIG.tmp" || true
            mv "$SIMLOG_CONFIG.tmp" "$SIMLOG_CONFIG"
        fi
    else
        if [[ -f "$SIMLOG_CONFIG" ]] && grep -q "^${key}=" "$SIMLOG_CONFIG"; then
            grep -v "^${key}=" "$SIMLOG_CONFIG" > "$SIMLOG_CONFIG.tmp" || true
            mv "$SIMLOG_CONFIG.tmp" "$SIMLOG_CONFIG"
        fi
        echo "${key}=\"$value\"" >> "$SIMLOG_CONFIG"
    fi
}

# Parse positional action (select simulator | set subsystem <value>)
if [[ $# -gt 0 && "$1" == "select" ]]; then
    ACTION="$1"; shift
    if [[ $# -gt 0 && "$1" == "simulator" ]]; then
        SUB_ACTION="$1"; shift
    else
        echo -e "${RED}Error: 'select' requires 'simulator' sub-action${NC}" >&2
        usage 1
    fi
elif [[ $# -gt 0 && "$1" == "set" ]]; then
    ACTION="$1"; shift
    if [[ $# -gt 0 && "$1" == "subsystem" ]]; then
        SUB_ACTION="$1"; shift
        if [[ $# -lt 1 ]]; then
            echo -e "${RED}Error: 'set subsystem' requires a value${NC}" >&2
            usage 1
        fi
        SET_VALUE="$1"; shift
    else
        echo -e "${RED}Error: 'set' requires 'subsystem' sub-action${NC}" >&2
        usage 1
    fi
fi

while [[ $# -gt 0 ]]; do
    case "$1" in
        -s|--subsystem)
            SUBSYSTEM="$2"
            shift 2
            ;;
        -c|--category)
            CATEGORIES+=("$2")
            shift 2
            ;;
        --simulator-id)
            SIMULATOR_ID="$2"
            shift 2
            ;;
        -h|--help)
            usage 0
            ;;
        *)
            echo -e "${RED}Error: Unknown option '$1'${NC}" >&2
            echo ""
            usage 1
            ;;
    esac
done

# Set subsystem action - persist subsystem to .simlogrc
if [[ "$ACTION" == "set" && "$SUB_ACTION" == "subsystem" ]]; then
    set_config SUBSYSTEM "$SET_VALUE"
    echo -e "${GREEN}Default subsystem set to: ${BOLD}$SET_VALUE${NC}"
    exit 0
fi

# Select simulator action
if [[ "$ACTION" == "select" && "$SUB_ACTION" == "simulator" ]]; then
    echo -e "${BLUE}Fetching available simulators...${NC}"

    simulators=()
    current_os=""
    while IFS= read -r line; do
        if [[ "$line" =~ ^--\ iOS\ (.+)\ --$ ]]; then
            current_os="${BASH_REMATCH[1]}"
        elif [[ "$line" =~ ^-- ]]; then
            current_os=""
        elif [[ -n "$current_os" ]] && SIM_RE='^[[:space:]]+(.+) \(([A-F0-9-]{36})\)' && [[ "$line" =~ $SIM_RE ]]; then
            name="${BASH_REMATCH[1]}"
            uuid="${BASH_REMATCH[2]}"
            simulators+=("${name}|${uuid}|${current_os}")
        fi
    done < <(xcrun simctl list devices available)

    if [[ ${#simulators[@]} -eq 0 ]]; then
        echo -e "${RED}Error: No simulators found${NC}"
        exit 1
    fi

    echo ""
    echo -e "${BOLD}Available simulators:${NC}"
    i=1
    for entry in "${simulators[@]}"; do
        IFS='|' read -r sim_name sim_uuid sim_os <<< "$entry"
        current_marker=""
        if [[ "$sim_uuid" == "${SIMULATOR_ID:-}" ]]; then
            current_marker=" ${GREEN}(current)${NC}"
        fi
        echo -e "  $i) ${sim_name} (iOS ${sim_os})${current_marker}"
        (( i++ ))
    done

    echo ""
    total=${#simulators[@]}
    echo -ne "${CYAN}Pick a simulator [1-$total]:${NC} "
    read -r choice

    if ! [[ "$choice" =~ ^[0-9]+$ ]] || [[ "$choice" -lt 1 || "$choice" -gt "$total" ]]; then
        echo -e "${RED}Invalid selection${NC}"
        exit 1
    fi

    selected="${simulators[$((choice - 1))]}"
    IFS='|' read -r selected_name selected_id selected_os <<< "$selected"

    set_config SIMULATOR_NAME "$selected_name"
    set_config SIMULATOR_ID "$selected_id"
    set_config SIMULATOR_OS "$selected_os"

    echo -e "${GREEN}Default simulator set to: ${BOLD}$selected_name${NC} ${GREEN}(iOS $selected_os)${NC}"
    exit 0
fi

if [[ -z "$SUBSYSTEM" ]]; then
    echo -e "${RED}Error: --subsystem is required${NC}" >&2
    echo ""
    usage 1
fi

# Build NSPredicate
PREDICATE="subsystem == \"$SUBSYSTEM\""

if [[ ${#CATEGORIES[@]} -gt 0 ]]; then
    CAT_PRED=""
    for cat in "${CATEGORIES[@]}"; do
        if [[ -n "$CAT_PRED" ]]; then
            CAT_PRED+=" OR "
        fi
        if [[ "$cat" == *"*"* ]]; then
            CAT_PRED+="category LIKE \"$cat\""
        else
            CAT_PRED+="category == \"$cat\""
        fi
    done
    PREDICATE+=" AND ($CAT_PRED)"
fi

# Target simulator: saved ID, else booted
TARGET="${SIMULATOR_ID:-booted}"
TARGET_LABEL="$TARGET"
if [[ -n "${SIMULATOR_ID:-}" ]]; then
    TARGET_LABEL="${SIMULATOR_NAME:-$SIMULATOR_ID}"
    if [[ -n "${SIMULATOR_OS:-}" ]]; then
        TARGET_LABEL="$TARGET_LABEL (iOS $SIMULATOR_OS)"
    fi
fi

echo -e "${BOLD}Streaming logs...${NC}"
echo -e "  ${CYAN}Simulator:${NC}  $TARGET_LABEL"
echo -e "  ${CYAN}Subsystem:${NC}  $SUBSYSTEM"
if [[ ${#CATEGORIES[@]} -gt 0 ]]; then
    echo -e "  ${CYAN}Categories:${NC} ${CATEGORIES[*]}"
fi
echo -e "  ${CYAN}Level:${NC}      debug"
echo -e "  ${CYAN}Style:${NC}      compact"
echo ""
echo -e "${YELLOW}Press Ctrl+C to stop${NC}"
echo ""

# Boot the simulator if a specific one was chosen and it's not already booted
if [[ -n "${SIMULATOR_ID:-}" ]]; then
    sim_state=$(xcrun simctl list devices | grep "$SIMULATOR_ID" | grep -oE '\((Booted|Shutdown)\)' | tr -d '()')
    if [[ "$sim_state" != "Booted" ]]; then
        echo -e "${YELLOW}Simulator is not booted. Run 'xcrun simctl boot $SIMULATOR_ID' first, or boot it via Xcode.${NC}" >&2
        exit 1
    fi
fi

xcrun simctl spawn "$TARGET" log stream \
    --level=debug \
    --predicate "$PREDICATE" \
    --style compact
