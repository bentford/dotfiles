alias gsfzf='git switch $(gb | fzf)'
alias gai="git add -i"
alias gfa="git forgit add"
alias gdh="git diff HEAD~1"
alias gcanm="git commit --all --no-verify --message"
alias gcnn!="git commit --no-verify --no-edit --amend"

alias gfsw="git-fetch-switch"
alias gfcb="git-fetch-checkout-branch"
alias ghpf="git-fetch-checkout-pr" # worktree-compatible version of ghph (gh pr checkout)
alias gfdcb="git-fetch-development-create-branch"
alias gfod="gfo development"
alias gfodd="gfo development:development"

alias gcb='git rev-parse --abbrev-ref HEAD'

alias ghpce='gh pr create -e'
alias ghpcd='gh pr create -e -d'
alias ghpm='gh pr merge --auto --merge'
alias ghph='gh pr checkout'
alias ghpv='gh pr view -w'
alias ghps='gh pr status'

export DERIVED_DATA="$HOME/Library/Developer/Xcode/DerivedData"

function git-fetch-switch() {
  if [ -z "$1" ]; then
    echo "Usage: git-fetch-switch <branch-name>"
    return 1
  fi

  local branch="$1"
  gfo "$branch:$branch"
  gsw "$branch"
}

function git-fetch-checkout-pr() {
  if [ -z "$1" ]; then
    echo "Usage: git-fetch-checkout-pr <pr-number>"
    return 1
  fi

  local branch
  branch=$(gh pr view "$1" --json headRefName --jq '.headRefName')
  if [ -z "$branch" ]; then
    echo "Could not find branch for PR $1"
    return 1
  fi

  git-fetch-checkout-branch "$branch"
}

function git-fetch-checkout-branch() {
  if [ -z "$1" ]; then
    echo "Usage: git-fetch-checkout-branch <branch-name>"
    return 1
  fi

  local branch="$1"
  git fetch origin "$branch":"refs/remotes/origin/$branch"
  git checkout -b "$branch" "origin/$branch"
}

function git-fetch-development-create-branch() {
  if [ -z "$1" ]; then
    echo "Usage: git-fetch-development-create-branch <branch-name>"
    return 1
  fi

  local branch="$1"
  gfo development:development
  gswc "$branch"
}

function mkdir-cp() {
  if [ $# -lt 2 ]; then
    echo "Usage: mkdir-cp <source> <destination>"
    return 1
  fi

  local dest="$2"

  # If destination ends with /, treat it as a directory
  if [[ "$dest" == */ ]]; then
    mkdir -p "$dest"
  else
    # Create parent directory of the destination file
    local dest_dir="$(dirname "$dest")"
    mkdir -p "$dest_dir"
  fi

  cp "$1" "$2"
}
